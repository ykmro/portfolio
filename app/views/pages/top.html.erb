<% content_for :head do %>
  <%= javascript_include_tag("pages/top") %>
<% end %>
<main class="top container">
  <section class="hero">
    <h2 class="title">役に立たない。<br>でも、忘れない。</h2>
    <p class="txt">
      新感覚エクストリーム英語学習アプリ。<br>
      一生訪れないかもしれない極限の状況で<br>
      生きるための英語を学びましょう。
    </p>
  </section>
  <section class="about">
    <h2 class="title">ABOUT <span>WHATIF?</span></h2>
    <p class="txt">
      実用的なビジネス英会話より、映画のふとしたフレーズが頭に残る。<br>
      それはきっと情景とともにあなたの脳に記憶されているから。<br>
      このアプリは、物語のワンシーンのような状況で英語を学ぶことができます。<br>
      「次はどんな場面が来るんだろう？」<br>
      純粋な好奇心で続けられる学びを目指します。
    </p>
  </section>
  <section class="scenes">
    <h2 class="title">SCENES</h2>
    <ul class="situations">
      <% @situations.each_with_index do |situation, index| %>
        <li class="situation">
          <div class="thum">
              <a href="<%= url_for(situation_path(situation)) %>">
                <%= image_tag "top/situation_thum_#{index + 1}.png" %>
              </a>
          </div>
          <div class="modal">
            <div class="inner">
              <div class="thum">
                <%= image_tag "top/situation_thum_#{index + 1}.png" %>
              </div>
              <div class="txts">
                <h3 class="title">
                  <%= situation.title %>
                </h3>
                <p class="txt overview">
                  <%= situation.overview %>
                </p>
                <p class="txt scenario">
                  <%= situation.scenario %>
                </p>
                <a class="button" href="<%= url_for(situation_path(situation)) %>">
                  NEXT
                </a>
              </div>
            </div>
          </div>
        </li>
      <% end %>
    </ul>
  </section>
  <span class="overlay"></span>
</main>
