<% content_for :head do %>
  <%= javascript_include_tag("pages/top") %>
<% end %>
<main class="situation show container">
  <section class="hero">
    <h1 class="page_title">SCENE</h1>
    <h2 class="situation_title">脱獄する時に使える英会話</h2>
    <div class="inner">
      <div class="thum">
        <%= image_tag "top/situation_thum_1.png" %>
      </div>
      <div class="txts">
        <p class="txt">
          <%= @step.body %>
        </p>
        <%= form_with url: next_step_path(@step), id: "choice_form", method: :post do |f| %>
          <% @choices.each do |choice| %>
            <div class="button_choice txt">
              <%= f.radio_button :choice_id, choice.id, data: { correct: choice.is_correct } %>
              <%= f.label :choice_id, choice.body, value: choice.id %>
              <button type="button" class="choice-speaker" data-text="<%= choice.body %>">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/>
                </svg>
              </button>
            </div>
          <% end %>
        <% end %>
        <div id="answer-overlay" class="answer-overlay">
          <p class="answer-overlay__message"></p>
        </div>
      </div>
    </div>
    <p class="step_progress txt"><%= @step.step_number %> / <%= @total_steps %></p>
  </section>
</main>
