<% content_for :head do %>
  <%= javascript_include_tag("pages/top") %>
<% end %>
<main class="situation show container">
  <section class="hero">
    <h1 class="page_title">SCENE</h1>
    <h2 class="situation_title"><%= @step.situation.title %></h2>
    <div class="inner">
      <div class="thum">
        <%= image_tag @step.situation.thumbnail %>
      </div>
      <div class="txts">
        <p class="txt bold"><%= @choice.body %></p>
        <p class="txt">
          <%= sanitize @choice.feedback, tags: ['br'] %>
        </p>
        <% if @next_step %>
          <a class="button" href="<%= step_path(@next_step) %>">
            次の問題へ
          </a>
        <% else %>
          <a class="button" href="<%= result_situation_path(@step.situation_id) %>">
            結果を見る
          </a>
        <% end %>
      </div>

    </div>
  </section>
</main>
