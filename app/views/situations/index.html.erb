<main class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <% @situations.each do |situation| %>
      <%= link_to situation_path(situation),
            class: "group block bg-white rounded-2xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-lg hover:scale-105 transition-all duration-300" do %>
        <div class="aspect-video overflow-hidden bg-gray-100">
          <%= image_tag situation.thumbnail, class: "w-full h-full object-cover", alt: situation.title %>
        </div>
        <div class="p-4">
          <h3 class="font-bold text-gray-900 text-sm mb-2 leading-snug"><%= situation.title %></h3>
          <p class="text-xs text-gray-500 leading-relaxed line-clamp-3"><%= situation.overview %></p>
        </div>
        <div class="px-4 pb-4">
          <span class="inline-flex items-center justify-center bg-primary text-white text-xs font-bold rounded-full px-4 py-1.5 group-hover:opacity-80 transition-opacity">
            はじめる
          </span>
        </div>
      <% end %>
    <% end %>
  </div>
</main>
