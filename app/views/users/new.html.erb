<main class="max-w-3xl mx-auto px-4 sm:px-6 py-16">
  <div class="max-w-md mx-auto">
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white text-center mb-8">会員登録</h1>

    <% if @user.errors.any? %>
      <div class="bg-red-50 dark:bg-red-900 border border-red-200 dark:border-red-700 rounded-2xl p-4 mb-6">
        <ul class="space-y-1">
          <% @user.errors.full_messages.each do |message| %>
            <li class="text-sm text-red-600 dark:text-red-300"><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @user, url: users_path, class: "bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 p-8 space-y-6 transition-colors duration-200" do |f| %>
      <div>
        <%= f.label :name, "ユーザー名", class: "block text-sm font-bold text-gray-700 dark:text-gray-300 mb-1.5" %>
        <%= f.text_field :name,
              class: "w-full rounded-xl border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-900 px-4 py-3 text-sm text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition",
              placeholder: "例）WHATIF太郎" %>
      </div>

      <div>
        <%= f.label :email, "メールアドレス", class: "block text-sm font-bold text-gray-700 dark:text-gray-300 mb-1.5" %>
        <%= f.email_field :email,
              class: "w-full rounded-xl border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-900 px-4 py-3 text-sm text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition",
              placeholder: "例）example@whatif.com" %>
      </div>

      <div>
        <%= f.label :password, "パスワード", class: "block text-sm font-bold text-gray-700 dark:text-gray-300 mb-1.5" %>
        <%= f.password_field :password,
              class: "w-full rounded-xl border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-900 px-4 py-3 text-sm text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition",
              placeholder: "6文字以上で入力してください" %>
      </div>

      <%= f.submit "登録する",
            class: "w-full bg-primary text-white text-sm font-bold rounded-full py-3 hover:opacity-80 transition-opacity cursor-pointer" %>
    <% end %>
  </div>
</main>
